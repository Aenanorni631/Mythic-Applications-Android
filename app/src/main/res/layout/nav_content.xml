<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0C29"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Assistant Tools"
        android:textColor="#6A5ACD"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnSavedLinksTool"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Saved Wiki Links"
        android:backgroundTint="#302B63"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnPatchNotesTool"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Official Patch Notes"
        android:backgroundTint="#302B63"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnInteractiveMapTool"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Interactive Map"
        android:backgroundTint="#302B63"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnQuickReferenceTool"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quick Reference"
        android:backgroundTint="#302B63"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="24dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#302B63"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="More tools and features are currently under development."
        android:textAlignment="center"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="italic" />
</LinearLayout>
